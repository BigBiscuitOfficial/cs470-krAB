#!/bin/bash
#SBATCH --job-name=fin-all-scale
#SBATCH --nodes=4
#SBATCH --ntasks=64
#SBATCH --cpus-per-task=16

set -euo pipefail

# IMPORTANT: submit this from the project root directory.
PROJECT_DIR="${SLURM_SUBMIT_DIR:-$PWD}"
cd "$PROJECT_DIR"

if [[ ! -d "$PROJECT_DIR/binaries" ]]; then
  echo "Missing binaries directory at: $PROJECT_DIR/binaries" >&2
  exit 1
fi

echo "Project dir: $PROJECT_DIR"
echo "Running serial, mt, mpi, mpi+mt scaling jobs in one allocation"

bash "$PROJECT_DIR/scripts/slurm/serial_batch.sh"
bash "$PROJECT_DIR/scripts/slurm/mt_batch.sh"
bash "$PROJECT_DIR/scripts/slurm/mpi_batch.sh"
bash "$PROJECT_DIR/scripts/slurm/mpi_mt_batch.sh"

echo "All scaling scripts completed."
